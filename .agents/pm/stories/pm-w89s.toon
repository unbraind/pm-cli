author: maintainer-agent
estimated_minutes: 30
acceptance_criteria: "Exemplar package builds a minimal custom PM CLI importing only @unbrained/pm-cli/sdk; it exercises create/update/close/claim, list/search/context, comments/notes/files/deps, validate/health, and a schema customization end-to-end in its linked tests; no src/core deep imports anywhere in the exemplar"
parent: pm-usfg
