{"ts":"2026-06-07T10:03:42.103Z","author":"audit-platform-agent","op":"create","patch":[{"op":"add","path":"/metadata/id","value":"pm-lold"},{"op":"add","path":"/metadata/title","value":"MCP ping method not handled — returns 'Unsupported MCP method' instead of empty response"},{"op":"add","path":"/metadata/description","value":"MCP protocol 2025-06-18 spec defines a `ping` method that should return an empty result `{}`. The pm-mcp server's handleRequest() falls through to `throw new PmCliError('Unsupported MCP method: ping', 64)` which writes a JSON-RPC error frame. Clients (e.g. Claude Code) that send ping for keep-alive get an error instead of a no-op. Evidence: server.ts line 1195 is the final throw; no case for 'ping' exists."},{"op":"add","path":"/metadata/type","value":"Issue"},{"op":"add","path":"/metadata/status","value":"open"},{"op":"add","path":"/metadata/priority","value":2},{"op":"add","path":"/metadata/tags","value":["area:mcp","bug","protocol"]},{"op":"add","path":"/metadata/created_at","value":"2026-06-07T10:03:42.103Z"},{"op":"add","path":"/metadata/updated_at","value":"2026-06-07T10:03:42.103Z"},{"op":"add","path":"/metadata/author","value":"audit-platform-agent"},{"op":"add","path":"/metadata/parent","value":"pm-5k4v"},{"op":"add","path":"/metadata/risk","value":"low"},{"op":"add","path":"/metadata/confidence","value":"high"}],"before_hash":"3cc22dff72be7b14824654a7a64ea62b04799939b2fee54c1b5f52ca60bf6df0","after_hash":"17cb52e4b4fa0500fb218fd956cfc7aeb5ee7181a3b22ab1e1d8de01b659d70b","message":""}
