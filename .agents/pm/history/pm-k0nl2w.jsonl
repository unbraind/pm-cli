{"ts":"2026-07-21T12:54:35.090Z","author":"codex-root","op":"learning_add","patch":[{"op":"replace","path":"/metadata/updated_at","value":"2026-07-21T12:54:35.090Z"},{"op":"add","path":"/metadata/learnings","value":[{"created_at":"2026-07-21T12:54:35.086Z","author":"codex-root","text":"Fallback settings need provenance, not just values. Consumers that perform external or background work must inspect settings-read warnings so safe CLI recovery does not become unsafe default-driven execution."}]}],"before_hash":"ec389688d24386ebd9e35cb69da1f01091e49c7eae43cc12bae7bfbc99f7ac04","after_hash":"0ddf1801c700cd8c4b94905400fb4bf4fa9af76a0372a42aebbfc80520d76abd"}
