{"ts":"2026-07-19T05:38:33.307Z","author":"maintainer-agent","op":"learning_add","patch":[{"op":"replace","path":"/metadata/updated_at","value":"2026-07-19T05:38:33.307Z"},{"op":"add","path":"/metadata/learnings","value":[{"created_at":"2026-07-19T05:38:33.306Z","author":"maintainer-agent","text":"A deterministic union of divergent history can be hash-chain valid while intentionally diverging from the independently merged current item. Treat strict verification as the post-merge detector and history-repair as the explicit reconciliation step; prove both in real Git acceptance tests."}]}],"before_hash":"011e4f344bdd4fe220a06f767b04f57c06761ffb6cf16ff09f274ee17e210d05","after_hash":"2b981287a2e10416d2aec5b8fb83a86e0a2a5dacfbdae62db66a274b7c86df80"}
