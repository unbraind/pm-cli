{"ts":"2026-07-13T15:28:07.544Z","author":"codex-sdk-contracts-20260713","op":"note_add","patch":[{"op":"replace","path":"/metadata/updated_at","value":"2026-07-13T15:28:07.544Z"},{"op":"add","path":"/metadata/notes","value":[{"created_at":"2026-07-13T15:28:07.544Z","author":"codex-sdk-contracts-20260713","text":"update-many already computes row status from actual per-item mutation results, and close is a lifecycle transition rather than a same-value scalar update. The phantom field defect was isolated to update's pre-diff changed_fields accumulation."}]}],"before_hash":"1b21bfcebc9d3233da7b4b8af40605af8ceb902fe8e42048f8bba6ed10b77210","after_hash":"0f6cdab211bac9313b21ee35c2a44059b3060abd99cfc779c6e795144e25bd70"}
