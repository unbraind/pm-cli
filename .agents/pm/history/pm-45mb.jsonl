{"ts":"2026-07-13T08:58:01.446Z","author":"maintainer-agent","op":"create","patch":[{"op":"add","path":"/metadata/id","value":"pm-45mb"},{"op":"add","path":"/metadata/title","value":"GH-534: no-op update reports phantom changed_fields in --json while TOON reports empty, and changed_field_count is always null in JSON"},{"op":"add","path":"/metadata/description","value":"A no-op pm update (field set to its current value) emits changed_fields:['title'] in --json but an empty changed_fields in TOON — the two formats disagree about whether anything changed; agents keying off JSON see phantom mutations. Additionally changed_field_count is computed for TOON but left null in the JSON envelope. Fix: compute changed_fields once from the actual before/after diff and share it across both renderers (uniform output contract — pm-srns territory), and populate changed_field_count as a number (0 for no-op). Check update-many/close envelopes for the same divergence at fix time."},{"op":"add","path":"/metadata/type","value":"Issue"},{"op":"add","path":"/metadata/status","value":"open"},{"op":"add","path":"/metadata/priority","value":2},{"op":"add","path":"/metadata/tags","value":["agent-ux","cli","gh-issue","json-output"]},{"op":"add","path":"/metadata/created_at","value":"2026-07-13T08:58:01.446Z"},{"op":"add","path":"/metadata/updated_at","value":"2026-07-13T08:58:01.446Z"},{"op":"add","path":"/metadata/author","value":"maintainer-agent"},{"op":"add","path":"/metadata/estimated_minutes","value":60},{"op":"add","path":"/metadata/acceptance_criteria","value":"No-op update reports empty changed_fields in BOTH json and toon; changed_field_count numeric in JSON (0 no-op, N real); update-many/close checked for the same divergence; regression tests; GH-534 closed"},{"op":"add","path":"/metadata/parent","value":"pm-mpbb"},{"op":"add","path":"/metadata/risk","value":"low"},{"op":"add","path":"/metadata/confidence","value":"high"},{"op":"add","path":"/metadata/dependencies","value":[{"id":"pm-srns","kind":"related","created_at":"2026-07-13T08:58:01.446Z"}]}],"before_hash":"3cc22dff72be7b14824654a7a64ea62b04799939b2fee54c1b5f52ca60bf6df0","after_hash":"76d6382dec8b6c7fd73c9036ff76e1abf73a4cf1550fc25b0ac92bb5e98049a2","message":""}
