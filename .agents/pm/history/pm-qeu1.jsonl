{"ts":"2026-05-16T21:58:02.396Z","author":"maintainer-agent","op":"create","patch":[{"op":"add","path":"/metadata/id","value":"pm-qeu1"},{"op":"add","path":"/metadata/title","value":"MCP pm_update --comment string crashes with 'values.map is not a function'"},{"op":"add","path":"/metadata/description","value":"Calling pm_update via MCP with options.comment='some text' (string, not array) crashes with `values.map is not a function`. Likely the same root cause as the tags-as-CSV fix (pm-1jcw from session 10) - comment/note/learning fields expect arrays and the MCP normalizer doesn't promote scalars. Workaround: call via CLI `pm comments <id> <text>`."},{"op":"add","path":"/metadata/type","value":"Issue"},{"op":"add","path":"/metadata/status","value":"open"},{"op":"add","path":"/metadata/priority","value":1},{"op":"add","path":"/metadata/tags","value":["agent-ux","mcp","pm-cli"]},{"op":"add","path":"/metadata/created_at","value":"2026-05-16T21:58:02.396Z"},{"op":"add","path":"/metadata/updated_at","value":"2026-05-16T21:58:02.396Z"},{"op":"add","path":"/metadata/author","value":"maintainer-agent"},{"op":"add","path":"/metadata/acceptance_criteria","value":"MCP pm_update accepts string scalars for comment/note/learning and promotes them to arrays; new test covers the normalization."},{"op":"add","path":"/metadata/parent","value":"pm-rnpb"}],"before_hash":"3cc22dff72be7b14824654a7a64ea62b04799939b2fee54c1b5f52ca60bf6df0","after_hash":"c21b23f3734e0fda8b783ee903afdfc846bd00c9839f94a5291282c3ea3b129d","message":""}
