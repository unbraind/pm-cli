{"ts":"2026-05-25T10:08:51.624Z","author":"codex-reliability-agent","op":"comment_add","patch":[{"op":"add","path":"/metadata/comments/1","value":{"created_at":"2026-05-25T10:08:51.624Z","author":"codex-reliability-agent","text":"Implementation complete: hardened TOCTOU read-then-lock windows uniformly across history-redact/history-repair/restore by snapshotting pre-lock history/item raw state and re-verifying under lock before any write. Commands now fail fast with EXIT_CODE.CONFLICT and retry guidance when the target history stream or item changed while waiting for lock, preventing stale rewrite commits. Regression coverage added in tests/unit/history-activity-command.spec.ts, tests/unit/history-repair-command.spec.ts, and tests/unit/restore-command.spec.ts via acquireLock spy mutation hooks. Verification: node scripts/run-tests.mjs test -- tests/unit/history-activity-command.spec.ts tests/unit/history-repair-command.spec.ts tests/unit/restore-command.spec.ts --reporter=dot (3 files, 43 tests passed)."}},{"op":"replace","path":"/metadata/updated_at","value":"2026-05-25T10:08:51.624Z"}],"before_hash":"acc526beaa186c1729abf1e77a6de5e6ef54814e58e8e088d8a4a6c0b772a42f","after_hash":"97f6d7efd46dd6e549baa9cd3ebbd60abc24a6c2cff1166779590b7a2a605492"}
