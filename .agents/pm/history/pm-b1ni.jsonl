{"ts":"2026-06-12T16:11:23.630Z","author":"maintainer-agent","op":"create","patch":[{"op":"add","path":"/metadata/id","value":"pm-b1ni"},{"op":"add","path":"/metadata/title","value":"pm validate --check-files misclassifies existing directories as deleted (GH-203, prune/auto-fix data-loss path)"},{"op":"add","path":"/metadata/description","value":"GH-203: src/cli/commands/validate.ts:1287 marks a linked path missing when stats.isFile() is false, so existing DIRECTORY links (accepted by pm files --add) classify as deleted. Because --prune-missing and --auto-fix act on deleted classifications, they would remove valid directory links (data loss). Regression scope: GH-184 feature shipped v2026.6.12 (pm-0v2m). Fix: treat stats.isDirectory() as present (or distinct directory classification excluded from prune), plus repro test with linked dir. Repro in GH-203 confirmed against 2026.6.12."},{"op":"add","path":"/metadata/type","value":"Issue"},{"op":"add","path":"/metadata/status","value":"open"},{"op":"add","path":"/metadata/priority","value":1},{"op":"add","path":"/metadata/tags","value":["area:validate","gh-triage-2026-06-12","regression"]},{"op":"add","path":"/metadata/created_at","value":"2026-06-12T16:11:23.630Z"},{"op":"add","path":"/metadata/updated_at","value":"2026-06-12T16:11:23.630Z"},{"op":"add","path":"/metadata/author","value":"maintainer-agent"}],"before_hash":"3cc22dff72be7b14824654a7a64ea62b04799939b2fee54c1b5f52ca60bf6df0","after_hash":"734699d8318564d4e311bbf683a6c80df037e2c894de0bbb63a5084dd876ac17","message":""}
