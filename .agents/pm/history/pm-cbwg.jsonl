{"ts":"2026-07-06T22:11:13.026Z","author":"maintainer-agent","op":"comment_add","patch":[{"op":"replace","path":"/metadata/updated_at","value":"2026-07-06T22:11:13.026Z"},{"op":"add","path":"/metadata/comments","value":[{"created_at":"2026-07-06T22:11:13.026Z","author":"maintainer-agent","text":"Prior-art note (audit #15 follow-up): unbraind already ships pm-starter and pm-ts-starter (reference EXTENSIONS covering all capability types). This exemplar is deliberately different — a standalone custom PM tool composed only from public SDK primitives, not an extension scaffold. Reference the starters for structure/CI conventions, do not duplicate them; if the exemplar drifts toward 'reference extension', fold it into pm-ts-starter upstream instead."}]}],"before_hash":"51164765a9db0068ce714322ab59269d071e57214bab1e440ea4993d8ba3f26d","after_hash":"b6c24501dcb0cfff09b1e7bda4c7ba628821fe9dcb8a5dddb546e1e6a8543a9a"}
