{"ts":"2026-07-05T04:54:31.164Z","author":"maintainer-agent","op":"create","patch":[{"op":"add","path":"/metadata/id","value":"pm-cbwg"},{"op":"add","path":"/metadata/title","value":"SDK-only exemplar: minimal custom PM CLI package proving the universal-tool story end-to-end"},{"op":"add","path":"/metadata/description","value":"A packages/ exemplar (e.g. pm-minimal) that assembles a working project-specific PM tool importing only @unbrained/pm-cli/sdk — custom types/statuses via schema primitives, custom commands via lifecycle/query primitives — serving as living documentation and the acceptance proof for story pm-w89s. Duplicate check: existing exemplars (pm-kanban etc.) demonstrate extension authoring, not SDK-only tool assembly."},{"op":"add","path":"/metadata/type","value":"Feature"},{"op":"add","path":"/metadata/status","value":"open"},{"op":"add","path":"/metadata/priority","value":2},{"op":"add","path":"/metadata/tags","value":["area:extensions","area:sdk","docs","exemplar"]},{"op":"add","path":"/metadata/created_at","value":"2026-07-05T04:54:31.164Z"},{"op":"add","path":"/metadata/updated_at","value":"2026-07-05T04:54:31.164Z"},{"op":"add","path":"/metadata/author","value":"maintainer-agent"},{"op":"add","path":"/metadata/estimated_minutes","value":300},{"op":"add","path":"/metadata/acceptance_criteria","value":"Exemplar package builds+tests using only public SDK imports; exercises lifecycle, query, annotations, governance, schema customization; linked tests run in CI; referenced from SDK docs as the build-your-own-PM-tool guide"},{"op":"add","path":"/metadata/parent","value":"pm-usfg"},{"op":"add","path":"/metadata/risk","value":"low"},{"op":"add","path":"/metadata/confidence","value":"medium"}],"before_hash":"3cc22dff72be7b14824654a7a64ea62b04799939b2fee54c1b5f52ca60bf6df0","after_hash":"37370c9d87e947f74b7da6125d409fb877ded271a48dfb93ed87a2122f5c777b","message":""}
