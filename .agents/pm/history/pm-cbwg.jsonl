{"ts":"2026-07-07T09:44:05.259Z","author":"codex-agent","op":"comment_add","patch":[{"op":"add","path":"/metadata/comments/2","value":{"created_at":"2026-07-07T09:44:05.259Z","author":"codex-agent","text":"Package exemplar update: pm-6abs verifies package doctor isolation and docs now describe hermetic package-author smoke tests, reducing machine-local global extension leakage during package development."}},{"op":"replace","path":"/metadata/updated_at","value":"2026-07-07T09:44:05.259Z"}],"before_hash":"314f9005be022658b6b76035f8d4a9b525b03529ce30f959f15699cae159bd61","after_hash":"58cbc1788868b40b32bb011518a52e111715896441d090fd6c5af4cdbc3495e8"}
