{"ts":"2026-05-16T22:07:55.319Z","author":"maintainer-agent","op":"create","patch":[{"op":"add","path":"/metadata/id","value":"pm-27yz"},{"op":"add","path":"/metadata/title","value":"CI: split quality+smoke gates into a parallel job, share dist via artifact"},{"op":"add","path":"/metadata/description","value":"Currently ubuntu/node20 runs build -> test -> coverage -> static-quality -> compatibility-check -> packaging-smoke -> npx-smoke -> plugin-smoke serially. Extract a build-once job that uploads dist + node_modules cache, then run build-test matrix in parallel with a 'gates' job that downloads dist and runs static/compat/packaging/smoke independently. Cuts ubuntu/20 critical path from ~12min to ~8min."},{"op":"add","path":"/metadata/type","value":"Issue"},{"op":"add","path":"/metadata/status","value":"open"},{"op":"add","path":"/metadata/priority","value":2},{"op":"add","path":"/metadata/tags","value":["ci","parallelism","performance","pm-cli"]},{"op":"add","path":"/metadata/created_at","value":"2026-05-16T22:07:55.319Z"},{"op":"add","path":"/metadata/updated_at","value":"2026-05-16T22:07:55.319Z"},{"op":"add","path":"/metadata/author","value":"maintainer-agent"},{"op":"add","path":"/metadata/acceptance_criteria","value":"build job uploads dist artifact; gates job downloads artifact and runs in parallel with matrix; ubuntu/20 critical path drops measurably; all gates still execute."},{"op":"add","path":"/metadata/parent","value":"pm-tzwy"}],"before_hash":"3cc22dff72be7b14824654a7a64ea62b04799939b2fee54c1b5f52ca60bf6df0","after_hash":"457c4b075e9fa99f285b31850e77db4f3391fa91cc84d979520f16ae290f42c4","message":""}
