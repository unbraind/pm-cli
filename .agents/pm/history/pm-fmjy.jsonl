{"ts":"2026-06-26T19:43:37.160Z","author":"codex","op":"comment_add","patch":[{"op":"add","path":"/metadata/comments/1","value":{"created_at":"2026-06-26T19:43:37.160Z","author":"codex","text":"Investigation note: CodeFactor docs for ignored files say folder/global file patterns are configured in repository Settings > Ignore Files, while files containing an auto-generated marker are ignored automatically. The hosted CodeFactor issue views still show paths covered by .codefactor.yml, so this branch adds explicit auto-generated markers to generated package runtime loaders and plugin MCP wrappers, with generator drift checks proving they are not hand-edited."}},{"op":"replace","path":"/metadata/updated_at","value":"2026-06-26T19:43:37.160Z"}],"before_hash":"aa207b7e910faef0fc2432bb78f7cd06d64ecf9d807114b0302db85875b77eb8","after_hash":"b9cf9c1f6c96518470c6410eed2934fca90b4cb665d83b08a16b7c316c8a68d9"}
