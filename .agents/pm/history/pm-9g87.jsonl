{"ts":"2026-06-27T20:44:06.865Z","author":"codex-implementation","op":"create","patch":[{"op":"add","path":"/metadata/id","value":"pm-9g87"},{"op":"add","path":"/metadata/title","value":"pm next hides completed-container closeout rows while leaf work exists"},{"op":"add","path":"/metadata/description","value":"Follow-up to pm-2n6i: pm next now ranks concrete ready leaf work ahead of 100%-complete open containers, but the default ready queue still emits completed-container closeout rows while actionable leaf work exists. Hide those governance closeout rows from the ready queue until there is no concrete leaf work, so agent loops stay token-focused on implementation work while still surfacing closeout when it becomes the next action."},{"op":"add","path":"/metadata/type","value":"Issue"},{"op":"add","path":"/metadata/status","value":"open"},{"op":"add","path":"/metadata/priority","value":2},{"op":"add","path":"/metadata/tags","value":["agent-ux","area:cli","context-management"]},{"op":"add","path":"/metadata/created_at","value":"2026-06-27T20:44:06.865Z"},{"op":"add","path":"/metadata/updated_at","value":"2026-06-27T20:44:06.865Z"},{"op":"add","path":"/metadata/author","value":"codex-implementation"},{"op":"add","path":"/metadata/parent","value":"pm-mpbb"},{"op":"add","path":"/metadata/comments","value":[{"created_at":"2026-06-27T20:44:06.865Z","author":"codex-implementation","text":"Duplicate check evidence: searched all statuses for 'pm next hide completed containers ready queue closeout concrete leaf'. Existing pm-2n6i is closed and only demoted completed containers; this follow-up narrows the output projection to hide closeout rows while concrete leaf work exists."}]}],"before_hash":"3cc22dff72be7b14824654a7a64ea62b04799939b2fee54c1b5f52ca60bf6df0","after_hash":"e8d21c8da0eae0392dad5bbdc0b0b3e9b299b520cb6754ee07d66de62c611151","message":""}
