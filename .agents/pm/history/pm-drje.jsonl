{"ts":"2026-05-05T18:05:44.169Z","author":"codex-release-agent","op":"create","patch":[{"op":"add","path":"/front_matter/id","value":"pm-drje"},{"op":"add","path":"/front_matter/title","value":"GitHub #21: document resilient global git-install recovery"},{"op":"add","path":"/front_matter/description","value":"Document and remediate GitHub issue #21: npm global install from the GitHub repository can fail with ENOTEMPTY and leave a broken pm symlink on reinstall."},{"op":"add","path":"/front_matter/type","value":"Issue"},{"op":"add","path":"/front_matter/status","value":"open"},{"op":"add","path":"/front_matter/priority","value":1},{"op":"add","path":"/front_matter/tags","value":["bug","docs","github","install","npm","pm-cli"]},{"op":"add","path":"/front_matter/created_at","value":"2026-05-05T18:05:44.169Z"},{"op":"add","path":"/front_matter/updated_at","value":"2026-05-05T18:05:44.169Z"},{"op":"add","path":"/front_matter/deadline","value":"2026-05-06T18:05:44.169Z"},{"op":"add","path":"/front_matter/author","value":"codex-release-agent"},{"op":"add","path":"/front_matter/estimated_minutes","value":90},{"op":"add","path":"/front_matter/acceptance_criteria","value":"The supported install/update path avoids broken global git symlink states or gives a deterministic recovery command; release/local docs and tests cover the install guidance; GitHub issue #21 is closed or updated with evidence."},{"op":"add","path":"/front_matter/parent","value":"pm-0rjf"},{"op":"add","path":"/front_matter/dependencies","value":[{"id":"pm-0rjf","kind":"parent","created_at":"2026-05-05T18:05:44.169Z","author":"codex-release-agent"}]},{"op":"add","path":"/front_matter/comments","value":[{"created_at":"2026-05-05T18:05:44.169Z","author":"codex-release-agent","text":"Duplicate-check evidence: ran pm search GitHub issue 21 npm install global git broken symlink ENOTEMPTY --limit 10. Results were closed install/history items,not an open tracker for GitHub issue #21,so this issue item records the external bug."}]},{"op":"add","path":"/front_matter/notes","value":[{"created_at":"2026-05-05T18:05:44.169Z","author":"codex-release-agent","text":"GitHub issue #21 reports npm install -g from the git repo can fail during reinstall and leave pm pointing to a deleted npm temp git clone. This is package-manager behavior,but the CLI release docs should make npm registry install/update the supported path and provide safe cleanup guidance for git-source installs."}]}],"before_hash":"3cc22dff72be7b14824654a7a64ea62b04799939b2fee54c1b5f52ca60bf6df0","after_hash":"688a7a221cee89ca05f3289073d1b804602187b85506eb9edb1fe52c5c5fea28","message":""}
