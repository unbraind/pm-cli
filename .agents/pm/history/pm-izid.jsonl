.md --title \\\"Changelog\\\" --mode replace --all-release-tags --status closed --item-url-base https://github.com/unbraind/pm-cli/blob/main/.agents/pm --check => unchanged."}},{"op":"replace","path":"/metadata/updated_at","value":"2026-06-06T21:26:52.147Z"}],"before_hash":"f1b60b9f1c29119edf6f324579d4d10ab2b4d1fbd8cc496fd2b07674c0204102","after_hash":"c5f63e569ea5d03292785a323f19dcfe31b84254862e8503d445adb81633bf49"}
