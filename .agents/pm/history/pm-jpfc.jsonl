{"ts":"2026-05-24T10:53:00.086Z","author":"codex-release","op":"comment_add","patch":[{"op":"add","path":"/metadata/comments/2","value":{"created_at":"2026-05-24T10:53:00.086Z","author":"codex-release","text":"Release workflow failure: GitHub run 26359132490 failed before npm publish at Reliability threshold gate. Logs show SENTRY_AUTH_TOKEN was present but issue lookup returned sentry_api_403; SENTRY_PERSONAL_ADMIN_TOKEN was empty. This matches the documented split where release upload tokens may not have issue-read scope and the issue-threshold gate should skip without the personal admin token."}},{"op":"replace","path":"/metadata/updated_at","value":"2026-05-24T10:53:00.086Z"}],"before_hash":"4fe72fdaf8370f8595db39d1dc4934c8c8b21a5ad493c2a4faf7e0fa84d89d41","after_hash":"e533d1eb1084693da1acce770c9d3cc2d3bc211024adb813e9d5f92089361950"}
