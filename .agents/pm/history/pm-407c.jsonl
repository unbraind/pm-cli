{"ts":"2026-05-29T22:28:36.468Z","author":"maintainer-agent","op":"create","patch":[{"op":"add","path":"/metadata/id","value":"pm-407c"},{"op":"add","path":"/metadata/title","value":"Semantic auto-defaults are all-or-nothing: one config leaf disables ALL defaults and hard-errors reindex"},{"op":"add","path":"/metadata/description","value":"semantic-defaults.ts hasAnyExplicitSemanticConfiguration returns true if ANY of 10 leaves is set, then applies ZERO defaults. Setting only ollama.base_url (even to the correct default) loses auto ollama.model+lancedb.path+search.embedding_model, and pm reindex then hard-errors. Fix: fill defaults PER-FIELD; only bail when a COMPETING provider/store is configured (openai/qdrant or non-ollama provider/non-lancedb adapter). Verified by vector-search dogfood."},{"op":"add","path":"/metadata/type","value":"Issue"},{"op":"add","path":"/metadata/status","value":"open"},{"op":"add","path":"/metadata/priority","value":2},{"op":"add","path":"/metadata/tags","value":["bug","config","search","semantic"]},{"op":"add","path":"/metadata/created_at","value":"2026-05-29T22:28:36.468Z"},{"op":"add","path":"/metadata/updated_at","value":"2026-05-29T22:28:36.468Z"},{"op":"add","path":"/metadata/author","value":"maintainer-agent"}],"before_hash":"3cc22dff72be7b14824654a7a64ea62b04799939b2fee54c1b5f52ca60bf6df0","after_hash":"abf7245130380cb3189749aa4c2ede16cfcc39a89a39055169e8a3b313e7e718","message":""}
