{"ts":"2026-06-21T20:35:07.534Z","author":"claude-code-agent","op":"create","patch":[{"op":"add","path":"/metadata/id","value":"pm-nhby"},{"op":"add","path":"/metadata/title","value":"pm package init --capability <kind>: scaffold capability-targeted starter packages (commands|hook)"},{"op":"add","path":"/metadata/description","value":"Extend the package scaffold (pm package init / pm extension init) with a --capability <kind> selector so authors get a runnable, fully-tested starter for the capability shape they actually want, not just the default 'commands' starter. kind=commands keeps current behavior (default). kind=hook scaffolds an after_command lifecycle reactor (the 'react to every mutation' pattern central to project management = context management): manifest declares the hooks capability, index.js registers api.hooks.afterCommand, and the package-mode sample test exercises activateExtensionForTest + assertRegisteredHook + runRegisteredHookForTest + deactivateExtensionForTest. Builds on pm-4ltc (runnable sample test) and exercises the runRegisteredHookForTest helper added under pm-miqm. Demonstrates the hooks-capability pillar end to end so authors can customize pm for any project archetype."},{"op":"add","path":"/metadata/type","value":"Feature"},{"op":"add","path":"/metadata/status","value":"open"},{"op":"add","path":"/metadata/priority","value":2},{"op":"add","path":"/metadata/tags","value":["area:cli","area:packages","area:sdk","pm-cli"]},{"op":"add","path":"/metadata/created_at","value":"2026-06-21T20:35:07.534Z"},{"op":"add","path":"/metadata/updated_at","value":"2026-06-21T20:35:07.534Z"},{"op":"add","path":"/metadata/author","value":"claude-code-agent"},{"op":"add","path":"/metadata/parent","value":"pm-ugqx"}],"before_hash":"3cc22dff72be7b14824654a7a64ea62b04799939b2fee54c1b5f52ca60bf6df0","after_hash":"f115ef3856bf465c6c3c2111d5bc0939e81f59bf1160a8fb189b3cf80f559573","message":""}
