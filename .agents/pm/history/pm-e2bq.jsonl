{"ts":"2026-07-05T04:53:35.309Z","author":"maintainer-agent","op":"create","patch":[{"op":"add","path":"/metadata/id","value":"pm-e2bq"},{"op":"add","path":"/metadata/title","value":"Tiered contracts-driven help: one-screen core help, full surface via pm help --all, generated from the contract table"},{"op":"add","path":"/metadata/description","value":"Default pm --help shows only the ~15 canonical nouns; pm help --all (and --explain) reveals the full surface incl. deprecated aliases; both views plus completions and docs command tables are generated from sdk/cli-contracts so help can never drift from contracts. Duplicate check: pm-5k2w (closed) trimmed help alias bloat once; no generated-tiered-help item exists."},{"op":"add","path":"/metadata/type","value":"Feature"},{"op":"add","path":"/metadata/status","value":"open"},{"op":"add","path":"/metadata/priority","value":1},{"op":"add","path":"/metadata/tags","value":["agent-ux","area:cli","area:contracts","simplification"]},{"op":"add","path":"/metadata/created_at","value":"2026-07-05T04:53:35.309Z"},{"op":"add","path":"/metadata/updated_at","value":"2026-07-05T04:53:35.309Z"},{"op":"add","path":"/metadata/author","value":"maintainer-agent"},{"op":"add","path":"/metadata/estimated_minutes","value":240},{"op":"add","path":"/metadata/acceptance_criteria","value":"pm --help renders one screen listing canonical nouns only; pm help --all lists everything incl. aliases marked deprecated; help/completions/docs command tables generated from the contract table with a drift gate; after-measurement (pm-a22j script) shows reduced default help + contracts token cost"},{"op":"add","path":"/metadata/parent","value":"pm-n7rr"},{"op":"add","path":"/metadata/risk","value":"medium"},{"op":"add","path":"/metadata/confidence","value":"medium"}],"before_hash":"3cc22dff72be7b14824654a7a64ea62b04799939b2fee54c1b5f52ca60bf6df0","after_hash":"82d2f98854ab4295b259d061546d1cc12b30a6b261c2822266db40a7750f1e8e","message":""}
