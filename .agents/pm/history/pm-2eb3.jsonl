{"ts":"2026-05-01T18:02:37.805Z","author":"audit-agent","op":"create","patch":[{"op":"replace","path":"/body","value":"Full audit executed 2026-05-01 in isolated temp directory. All 10 item types, all views, all lifecycle commands, SDK exports, starter extension, telemetry queue/pipeline, remote stack (Grafana/Alloy/Loki/Tempo/Prometheus/RabbitMQ/Postgres), and governance features verified."},{"op":"add","path":"/front_matter/id","value":"pm-2eb3"},{"op":"add","path":"/front_matter/title","value":"2026-05-01 Full PM CLI Dogfood Audit v2"},{"op":"add","path":"/front_matter/description","value":"Comprehensive dogfood audit of pm CLI v2026.5.1-2 covering core commands, SDK, calendar, telemetry pipeline, and extensibility. Successor to pm-23me."},{"op":"add","path":"/front_matter/type","value":"Epic"},{"op":"add","path":"/front_matter/status","value":"open"},{"op":"add","path":"/front_matter/priority","value":0},{"op":"add","path":"/front_matter/tags","value":["audit","calendar","dogfood","extensibility","pm-cli","sdk","telemetry"]},{"op":"add","path":"/front_matter/created_at","value":"2026-05-01T18:02:37.805Z"},{"op":"add","path":"/front_matter/updated_at","value":"2026-05-01T18:02:37.805Z"},{"op":"add","path":"/front_matter/deadline","value":"2026-05-08T18:02:37.805Z"},{"op":"add","path":"/front_matter/author","value":"audit-agent"},{"op":"add","path":"/front_matter/estimated_minutes","value":480},{"op":"add","path":"/front_matter/acceptance_criteria","value":"All audit phases documented with evidence; all issues tracked; telemetry pipeline verified end-to-end"},{"op":"add","path":"/front_matter/parent","value":"pm-23me"},{"op":"add","path":"/front_matter/dependencies","value":[{"id":"pm-23me","kind":"parent","created_at":"2026-05-01T18:02:37.805Z","author":"audit-agent"}]},{"op":"add","path":"/front_matter/comments","value":[{"created_at":"2026-05-01T18:02:37.805Z","author":"audit-agent","text":"Duplicate check: pm-23me is predecessor from 2026-04-30 and still open. This v2 audit covers the latest 2026.5.1-2 build with comprehensive end-to-end verification."}]}],"before_hash":"3cc22dff72be7b14824654a7a64ea62b04799939b2fee54c1b5f52ca60bf6df0","after_hash":"29bff99ad89895269d9ad4e7082926f1bcdc7d6b7812912f8bfcca24a87a0e7d","message":"Create v2 dogfood audit epic"}
{"ts":"2026-05-01T18:08:36.350Z","author":"audit-agent","op":"learning_add","patch":[{"op":"replace","path":"/front_matter/updated_at","value":"2026-05-01T18:08:36.350Z"},{"op":"add","path":"/front_matter/learnings","value":[{"created_at":"2026-05-01T18:08:36.350Z","author":"audit-agent","text":"Telemetry payloads must be bounded by total serialized size, not just element counts. summarizeResult() limits arrays to 5 samples but nested values within samples are unbounded, leading to 3-5MB events that get rejected by Cloudflare."}]}],"before_hash":"29bff99ad89895269d9ad4e7082926f1bcdc7d6b7812912f8bfcca24a87a0e7d","after_hash":"f3fdbf34b38452868cb95fe38dd4dc74dc6e1c1e861183cf873c83735e219648"}
{"ts":"2026-05-01T18:08:44.126Z","author":"audit-agent","op":"learning_add","patch":[{"op":"add","path":"/front_matter/learnings/1","value":{"created_at":"2026-05-01T18:08:44.126Z","author":"audit-agent","text":"The --event flag uses start= not start_at= for the start time parameter. This is consistent with the CSV KV parser but differs from the underlying field name in the item schema."}},{"op":"replace","path":"/front_matter/updated_at","value":"2026-05-01T18:08:44.126Z"}],"before_hash":"f3fdbf34b38452868cb95fe38dd4dc74dc6e1c1e861183cf873c83735e219648","after_hash":"a1506d6f56c683e0e183e07ca8c443c58cb8faa40d9e4c7af6736097a4af9fc6"}
{"ts":"2026-05-01T18:08:51.515Z","author":"audit-agent","op":"learning_add","patch":[{"op":"add","path":"/front_matter/learnings/2","value":{"created_at":"2026-05-01T18:08:51.515Z","author":"audit-agent","text":"--compact and --fields are mutually exclusive list projection options. Using both produces an explicit, actionable error with examples."}},{"op":"replace","path":"/front_matter/updated_at","value":"2026-05-01T18:08:51.515Z"}],"before_hash":"a1506d6f56c683e0e183e07ca8c443c58cb8faa40d9e4c7af6736097a4af9fc6","after_hash":"78120613ebf532861f32fab866858dde2b15b7572d76beab3ce9a4e0b960c9f8"}
{"ts":"2026-05-01T18:08:59.335Z","author":"audit-agent","op":"learning_add","patch":[{"op":"add","path":"/front_matter/learnings/3","value":{"created_at":"2026-05-01T18:08:59.335Z","author":"audit-agent","text":"Extension doctor with --detail deep provides comprehensive health analysis including unmanaged extension detection. Starter extension activates cleanly but shows expected unmanaged warning when copied manually."}},{"op":"replace","path":"/front_matter/updated_at","value":"2026-05-01T18:08:59.335Z"}],"before_hash":"78120613ebf532861f32fab866858dde2b15b7572d76beab3ce9a4e0b960c9f8","after_hash":"0024c198c576ef767487c3db17011a234f78108b2f003f14a0249b7de74f5af2"}
