{"ts":"2026-06-10T08:52:42.534Z","author":"maintainer-agent","op":"create","patch":[{"op":"add","path":"/metadata/id","value":"pm-xnkd"},{"op":"add","path":"/metadata/title","value":"pm close --duplicate-of: structured duplicate tracking with auto-populated closure fields (GH-183, GH-160)"},{"op":"add","path":"/metadata/description","value":"Add --duplicate-of <id> to pm close: validates target exists and is not itself closed-as-duplicate, sets duplicate_of metadata on the closed item, auto-populates resolution/expected_result/actual_result (suppressing close_validation_missing_fields warnings), standardizes the close reason, and adds a comment on the canonical item. Fixes GitHub issues #183 and #160."},{"op":"add","path":"/metadata/type","value":"Feature"},{"op":"add","path":"/metadata/status","value":"open"},{"op":"add","path":"/metadata/priority","value":1},{"op":"add","path":"/metadata/tags","value":["agent-ux","cli","close"]},{"op":"add","path":"/metadata/created_at","value":"2026-06-10T08:52:42.534Z"},{"op":"add","path":"/metadata/updated_at","value":"2026-06-10T08:52:42.534Z"},{"op":"add","path":"/metadata/author","value":"maintainer-agent"},{"op":"add","path":"/metadata/parent","value":"pm-mpbb"}],"before_hash":"3cc22dff72be7b14824654a7a64ea62b04799939b2fee54c1b5f52ca60bf6df0","after_hash":"e19ed5cab39cd2164aca2507897c0240162fe6d05a6766b775e401dbbad72730","message":""}
