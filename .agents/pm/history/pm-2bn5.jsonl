{"ts":"2026-06-07T17:04:16.436Z","author":"maintainer-agent","op":"create","patch":[{"op":"add","path":"/metadata/id","value":"pm-2bn5"},{"op":"add","path":"/metadata/title","value":"Settings read cache: memoize readSettingsWithMetadata across the 3-5 reads per command"},{"op":"add","path":"/metadata/description","value":"Biggest remaining per-command perf lever (code-quality audit F1): readSettingsWithMetadata is re-read+validated+merged+schema-loaded 3-5x per command (~9 FS syscalls each). DESIGN CONSTRAINTS: must key the cache on settings.json AND schema/*.json mtimes (schema files change independently via pm schema commands -> a settings.json-only key serves stale schema), keep onRead hooks firing each call, stay correct for the long-lived MCP server (external edits), and invalidate on writeSettings. Add a small tested src/core/store module to vitest include at 100%."},{"op":"add","path":"/metadata/type","value":"Feature"},{"op":"add","path":"/metadata/status","value":"open"},{"op":"add","path":"/metadata/priority","value":1},{"op":"add","path":"/metadata/tags","value":["area:performance"]},{"op":"add","path":"/metadata/created_at","value":"2026-06-07T17:04:16.436Z"},{"op":"add","path":"/metadata/updated_at","value":"2026-06-07T17:04:16.436Z"},{"op":"add","path":"/metadata/author","value":"maintainer-agent"},{"op":"add","path":"/metadata/parent","value":"pm-mpbb"}],"before_hash":"3cc22dff72be7b14824654a7a64ea62b04799939b2fee54c1b5f52ca60bf6df0","after_hash":"78457462c015fadb1b30e23c6f261c13e310e0b94c76df97e757438044833c62","message":""}
