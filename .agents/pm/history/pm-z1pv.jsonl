{"ts":"2026-07-02T21:55:41.688Z","author":"claude-code-agent","op":"create","patch":[{"op":"add","path":"/metadata/id","value":"pm-z1pv"},{"op":"add","path":"/metadata/title","value":"Perf: pm context / pm next hot path ~700ms on an ~850-item tracker"},{"op":"add","path":"/metadata/description","value":"From 2026-07-02 audit (Lane D, pm-3l76): node startup is ~60ms, but pm context --limit 5 and pm next take ~700ms warm on this repo (857 items); list-open ~430ms, get ~335ms. Dominant cost is full-corpus load + actionability scan. Candidates: reuse/extend the front-matter cache on the context/next path, lazy-load bodies, avoid re-parsing closed items for ready-leaf computation. Target: common reads under ~300ms."},{"op":"add","path":"/metadata/type","value":"Task"},{"op":"add","path":"/metadata/status","value":"open"},{"op":"add","path":"/metadata/priority","value":2},{"op":"add","path":"/metadata/tags","value":["audit-followup","performance"]},{"op":"add","path":"/metadata/created_at","value":"2026-07-02T21:55:41.688Z"},{"op":"add","path":"/metadata/updated_at","value":"2026-07-02T21:55:41.688Z"},{"op":"add","path":"/metadata/author","value":"claude-code-agent"}],"before_hash":"3cc22dff72be7b14824654a7a64ea62b04799939b2fee54c1b5f52ca60bf6df0","after_hash":"159044af89d3188860be6c26a8d614201e105d9a9e21807aa087b1e1b8aa9fa1","message":""}
