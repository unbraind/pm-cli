{"ts":"2026-05-01T22:38:17.021Z","author":"audit-agent","op":"create","patch":[{"op":"add","path":"/front_matter/id","value":"pm-cd2f"},{"op":"add","path":"/front_matter/title","value":"Performance: list/filter operations scan all 625+ item files on each invocation"},{"op":"add","path":"/front_matter/description","value":"Every list/search/context/calendar command reads all item files from disk. With 625+ items, this adds 600-1000ms per invocation. A manifest index cache (invalidated on mutations via updated_at tracking) would reduce list operations to near-instant for cached reads. Telemetry confirms P50 for list-open is 732ms, P95 is 2576ms."},{"op":"add","path":"/front_matter/type","value":"Feature"},{"op":"add","path":"/front_matter/status","value":"open"},{"op":"add","path":"/front_matter/priority","value":1},{"op":"add","path":"/front_matter/tags","value":["core","performance","pm-cli"]},{"op":"add","path":"/front_matter/created_at","value":"2026-05-01T22:38:17.021Z"},{"op":"add","path":"/front_matter/updated_at","value":"2026-05-01T22:38:17.021Z"},{"op":"add","path":"/front_matter/author","value":"audit-agent"},{"op":"add","path":"/front_matter/parent","value":"pm-rrjv"}],"before_hash":"3cc22dff72be7b14824654a7a64ea62b04799939b2fee54c1b5f52ca60bf6df0","after_hash":"2521ffc0c3225a2c4dc0a96ecec0e9e34085a2050d81096cc9babee45362f941","message":"Performance finding from telemetry analysis"}
