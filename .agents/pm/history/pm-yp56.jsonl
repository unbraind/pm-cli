{"ts":"2026-07-18T10:08:09.956Z","author":"maintainer-agent","op":"create","patch":[{"op":"add","path":"/metadata/id","value":"pm-yp56"},{"op":"add","path":"/metadata/title","value":"GH-588: pm comment --message exits 0 recording nothing — comment invocation without any comment text must fail fast"},{"op":"add","path":"/metadata/description","value":"GitHub issue #588: --message on the comments command is the history-message flag, not comment text; an invocation carrying no comment source (no positional text, no --add, no stdin/file) exits 0 with count:0 and records nothing. Fix = fail fast with actionable guidance (use --add/positional/stdin) or at minimum warn that only a history message was recorded."},{"op":"add","path":"/metadata/type","value":"Issue"},{"op":"add","path":"/metadata/status","value":"open"},{"op":"add","path":"/metadata/priority","value":2},{"op":"add","path":"/metadata/tags","value":["agent-ux","cli","silent-failure"]},{"op":"add","path":"/metadata/created_at","value":"2026-07-18T10:08:09.956Z"},{"op":"add","path":"/metadata/updated_at","value":"2026-07-18T10:08:09.956Z"},{"op":"add","path":"/metadata/author","value":"maintainer-agent"},{"op":"add","path":"/metadata/estimated_minutes","value":90},{"op":"add","path":"/metadata/acceptance_criteria","value":"Comment invocation with no comment text errors (or warns) with guidance naming --add/positional/stdin; exit code non-zero on the error path; contract + regression coverage; --message continues to set the history message when comment text is present"},{"op":"add","path":"/metadata/parent","value":"pm-mpbb"},{"op":"add","path":"/metadata/risk","value":"low"},{"op":"add","path":"/metadata/confidence","value":"high"},{"op":"add","path":"/metadata/dependencies","value":[{"id":"pm-45mb","kind":"related","created_at":"2026-07-18T10:08:09.956Z"},{"id":"pm-gdi7","kind":"related","created_at":"2026-07-18T10:08:09.956Z"}]}],"before_hash":"3cc22dff72be7b14824654a7a64ea62b04799939b2fee54c1b5f52ca60bf6df0","