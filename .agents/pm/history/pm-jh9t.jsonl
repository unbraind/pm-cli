{"ts":"2026-07-13T08:57:37.424Z","author":"maintainer-agent","op":"create","patch":[{"op":"add","path":"/metadata/id","value":"pm-jh9t"},{"op":"add","path":"/metadata/title","value":"GH-532: --estimated-minutes accepts negative numbers and floats — missing non-negative-integer range validation"},{"op":"add","path":"/metadata/description","value":"pm update --estimated-minutes -5 and 1.5 both succeed (exit 0) and persist, while non-numeric input is correctly rejected — the coercion validates type but not range/integrality. Negative effort corrupts aggregate sums and flow metrics. Fix: reject negatives (and either reject or round-document fractionals) with the same 'Invalid argument value' error shape used for non-numeric input, at the shared numeric-coercion site so create/update/update-many all inherit it. Same silent-wrong-data family as pm-96vo/pm-kj4k."},{"op":"add","path":"/metadata/type","value":"Issue"},{"op":"add","path":"/metadata/status","value":"open"},{"op":"add","path":"/metadata/priority","value":3},{"op":"add","path":"/metadata/tags","value":["cli","gh-issue","validation"]},{"op":"add","path":"/metadata/created_at","value":"2026-07-13T08:57:37.424Z"},{"op":"add","path":"/metadata/updated_at","value":"2026-07-13T08:57:37.424Z"},{"op":"add","path":"/metadata/author","value":"maintainer-agent"},{"op":"add","path":"/metadata/estimated_minutes","value":45},{"op":"add","path":"/metadata/acceptance_criteria","value":"Negative and non-integer --estimated-minutes rejected on create/update/update-many with domain-stating error; existing stored invalid values unaffected; regression tests; GH-532 closed"},{"op":"add","path":"/metadata/parent","value":"pm-mpbb"},{"op":"add","path":"/metadata/risk","value":"low"},{"op":"add","path":"/metadata/confidence","value":"high"},{"op":"add","path":"/metadata/dependencies","value":[{"id":"pm-96vo","kind":"related","created_at":"2026-07-13T08:57:37.424Z"}]}],"before_hash":"3cc22dff72be7b14824654a7a64ea62b04799939b2fee54c1b5f52