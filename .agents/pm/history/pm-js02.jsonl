{"ts":"2026-06-25T00:06:32.677Z","author":"codex-audit-20260625","op":"create","patch":[{"op":"add","path":"/metadata/id","value":"pm-js02"},{"op":"add","path":"/metadata/title","value":"Package lifecycle typo recovery should suggest action subcommands"},{"op":"add","path":"/metadata/description","value":"When users run mistyped package/extension lifecycle actions such as pm package descirbe --json or pm package catalogx --json, the lifecycle parser treats the token as a target and emits a generic missing-action error whose recovery suggests --install \"<value>\". Agents should get typo-aware suggestions for valid action subcommands such as describe or catalog instead. Duplicate check 2026-06-25: pm search --status all for package extension lifecycle typo recovery descirbe catalogx target install suggestions found related package/extension work but no exact item."},{"op":"add","path":"/metadata/type","value":"Issue"},{"op":"add","path":"/metadata/status","value":"in_progress"},{"op":"add","path":"/metadata/priority","value":2},{"op":"add","path":"/metadata/tags","value":["agent-ux","area:cli","dx","recovery"]},{"op":"add","path":"/metadata/created_at","value":"2026-06-25T00:06:32.677Z"},{"op":"add","path":"/metadata/updated_at","value":"2026-06-25T00:06:32.677Z"},{"op":"add","path":"/metadata/author","value":"codex-audit-20260625"},{"op":"add","path":"/metadata/parent","value":"pm-mpbb"}],"before_hash":"3cc22dff72be7b14824654a7a64ea62b04799939b2fee54c1b5f52ca60bf6df0","after_hash":"15aa4bc137b3e76e29c5a595d0a3f51ee08ae18b159722324f2ec854b97c09ba","message":""}
