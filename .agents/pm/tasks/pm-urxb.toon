reviewer: maintainer-review
risk: medium
confidence: medium
sprint: governance-followups
release: vnext
reporter: codex-agent
severity: medium
environment: linux
repro_steps: Run pm validate --check-lifecycle against projects with different blocker/resolution wording and observe static pattern limitations.
affected_version: 2026.3.12
fixed_version: target-vnext
component: validate-lifecycle
regression: false
customer_impact: Maintainers get tunable lifecycle diagnostics with less manual suppression.
