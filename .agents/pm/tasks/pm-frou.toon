resolution: "pm extension/package init emits index.ts + tsconfig.json (NodeNext, types:[node], no outDir) + build/test scripts + @types/node; manifest entry stays compiled ./index.js. Manual compile+node:test verified for all 4 capabilities."
dependencies[1]{id,kind,created_at,author,source_kind}:
