  README.md,project,document deterministic duplicate-skip orchestration behavior
  src/cli/commands/test-all.ts,project,deduplicate execution keys for linked tests
  src/cli/commands/test.ts,project,export shared linked-test runner for test-all dedupe
  src/commands/test.ts,project,keep legacy wrapper export surface aligned after runLinkedTests export
  tests/unit/test-all-command.spec.ts,project,add duplicate skip behavior coverage
tests[1]{command,path,scope,timeout_seconds,note}:
  node scripts/run-tests.mjs test -- tests/unit/test-all-command.spec.ts,null,project,900,targeted test-all dedupe behavior regression
docs[2]{path,scope,note}:
