learnings[1]{created_at,author,text}:
  "2026-07-18T11:37:36.849Z",maintainer-agent,"Extension command collision safety needs canonical alias awareness: preserve legitimate core handler registration while rejecting aliases and nested grafts that shadow core ownership."
