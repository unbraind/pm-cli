author: maintainer-agent
estimated_minutes: 120
acceptance_criteria: "All linked-path resolution surfaces (files/docs --add, --add-glob expansion, --discover containment, --validate-paths probing) anchor stored paths at resolveWorkspaceRoot(pmRoot), not process.cwd(); relative CLI input is interpreted against cwd then re-anchored to the workspace root before storage; a subdirectory-cwd regression test proves pm files --add + pm validate --check-files agree; SDK docs for runFiles/runFilesDiscover/validateLinkedPaths state the workspace-root anchoring contract"
