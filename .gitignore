node_modules/
dist/
coverage/
.cache/
.gemini/
.codex/
.env
.sentryclirc
# Local vector store and search index cache (optional, rebuilt on demand via pm reindex).
# Ignore the search/ cache CONTENTS but keep the directory re-includable so the curated,
# git-tracked golden-query set (pm eval, pm-u8n5) lives at .agents/pm/search/eval-queries.json.
.agents/pm/search/*
!.agents/pm/search/eval-queries.json
.agents/pm/index/manifest.json
.agents/pm/checkpoints/
.agents/pm/runtime/front-matter-cache.json
.agents/pm/runtime/metadata-cache.json
.agents/pm/runtime/metadata-cache-bodies.json
.agents/pm/runtime/metadata-cache-collections.json
.agents/pm/runtime/history-drift-cache.json
.agents/pm/runtime/session.json
.agents/pm/runtime/telemetry/

# Local profiling artifacts must not be committed.
*.cpuprofile
*.heapprofile
*.heapsnapshot

# Local production operations artifacts are private and must not be committed.
scripts/prod/
scripts/prod/telemetry/
scripts/prod/telemetry/**
.claude/
