{
  "path": [
    "src",
    "packages",
    "plugins",
    "scripts",
    "docs/examples",
    "tests"
  ],
  "format": [
    "typescript",
    "javascript"
  ],
  "mode": "strict",
  "minLines": 22,
  "minTokens": 115,
  "threshold": 0,
  "reporters": [
    "console"
  ],
  "noTips": true,
  "ignore": [
    "**/.agents/**",
    "**/.cache/**",
    "**/.codex/**",
    "**/.gemini/**",
    "**/.pnpm-store/**",
    "**/coverage/**",
    "**/dist/**",
    "**/node_modules/**",
    "packages/pm-*/extensions/*/runtime-loader.ts",
    "plugins/pm-*/scripts/pm-mcp-server.mjs"
  ]
}
