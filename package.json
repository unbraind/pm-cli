{
  "name": "@unbrained/pm-cli",
  "version": "2026.7.14",
  "description": "Git-native project management CLI for humans and agents.",
  "type": "module",
  "packageManager": "pnpm@11.10.0",
  "author": "unbrained",
  "homepage": "https://github.com/unbraind/pm-cli#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unbraind/pm-cli.git"
  },
  "bugs": {
    "url": "https://github.com/unbraind/pm-cli/issues"
  },
  "bin": {
    "pm-cli": "dist/cli.js",
    "pm": "dist/cli.js",
    "pm-mcp": "dist/mcp/server.js"
  },
  "types": "dist/sdk/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/sdk/index.d.ts",
      "import": "./dist/cli-bundle/sdk.js",
      "default": "./dist/cli-bundle/sdk.js"
    },
    "./sdk": {
      "types": "./dist/sdk/index.d.ts",
      "import": "./dist/cli-bundle/sdk.js",
      "default": "./dist/cli-bundle/sdk.js"
    },
    "./sdk/runtime": {
      "types": "./dist/sdk/runtime.d.ts",
      "import": "./dist/cli-bundle/sdk-runtime.js",
      "default": "./dist/cli-bundle/sdk-runtime.js"
    },
    "./sdk/testing": {
      "types": "./dist/sdk/testing.d.ts",
      "import": "./dist/cli-bundle/sdk-testing.js",
      "default": "./dist/cli-bundle/sdk-testing.js"
    },
    "./cli": {
      "types": "./dist/cli/main.d.ts",
      "import": "./dist/cli/main.js",
      "default": "./dist/cli/main.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**",
    "README.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "CODE_OF_CONDUCT.md",
    "LICENSE",
    "AGENTS.md",
    "docs/**",
    ".claude-plugin/**",
    "plugins/**",
    "packages/pm-*/**",
    "scripts/bundle-cli.mjs",
    "scripts/finalize-build.mjs",
    "scripts/install.sh",
    "scripts/install.ps1",
    "scripts/prepare-build-cache.mjs",
    "marketplace.json"
  ],
  "scripts": {
    "build": "node scripts/prepare-build-cache.mjs && tsc -p tsconfig.json && node scripts/bundle-cli.mjs && node scripts/finalize-build.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc -p tsconfig.packages.json && tsc -p tsconfig.examples.json",
    "start": "node dist/cli.js",
    "dev": "tsx src/cli.ts",
    "test": "node scripts/run-tests.mjs test",
    "test:coverage": "node scripts/run-tests.mjs coverage",
    "lint": "pnpm lint:eslint && pnpm lint:duplicates && pnpm lint:codefactor",
    "lint:eslint": "eslint . --max-warnings=0",
    "lint:eslint:prune": "eslint . --prune-suppressions",
    "lint:complexity:baseline": "eslint . --suppress-rule complexity --suppress-rule sonarjs/cognitive-complexity",
    "lint:duplicates": "jscpd --config .jscpd.json",
    "lint:codefactor": "pnpm quality:static",
    "quality:static": "pnpm build && node scripts/release/static-quality-gate.mjs --min-docstring-coverage 100 --min-exported-docstring-coverage 100 --min-member-docstring-coverage 100 && node scripts/release/audit-package-boundary.mjs && node scripts/release/token-budget-gate.mjs",
    "quality:token-budget": "node scripts/release/token-budget-gate.mjs",
    "quality:context-eval": "node scripts/release/context-eval-gate.mjs",
    "quality:docs-skills": "node scripts/release/docs-skills-gate.mjs",
    "quality:docs-links": "node scripts/release/docs-skills-gate.mjs --links-only",
    "benchmark:scale:generate": "node scripts/bench/scale-workspace.mjs",
    "benchmark:scale": "node scripts/bench/run-scale-benchmarks.mjs",
    "benchmark:scale:check": "node scripts/bench/run-scale-benchmarks.mjs --items ci --iterations 3 --transport both --check --output .cache/scale-local-report.json",
    "contracts:update": "node scripts/contracts-snapshot.mjs --update",
    "contracts:check": "node scripts/contracts-snapshot.mjs --check",
    "dogfood:package-first": "node scripts/dogfood-package-first.mjs",
    "smoke:external-packages": "node scripts/smoke-external-packages.mjs",
    "smoke:codex-plugin": "node scripts/smoke-codex-plugin-mcp.mjs",
    "smoke:claude-plugin": "node scripts/smoke-claude-plugin.mjs",
    "version:check": "node scripts/release-version.mjs check && node scripts/sync-versions.mjs check",
    "version:next": "node scripts/release-version.mjs next",
    "version:sync": "node scripts/sync-versions.mjs apply",
    "changelog:pm:install": "node dist/cli.js install npm:pm-changelog --project",
    "changelog:pm": "pnpm changelog:pm:install && node dist/cli.js changelog generate --output CHANGELOG.md --title \"Changelog\" --mode replace --all-release-tags --status closed --item-url-base https://github.com/unbraind/pm-cli/blob/main/.agents/pm",
    "changelog:pm:check": "pnpm changelog:pm:install && node dist/cli.js changelog generate --output CHANGELOG.md --title \"Changelog\" --mode replace --all-release-tags --status closed --item-url-base https://github.com/unbraind/pm-cli/blob/main/.agents/pm --check",
    "release:notes": "node scripts/generate-release-notes.mjs",
    "release:gates": "node scripts/release/run-gates.mjs --telemetry-mode best-effort",
    "release:pipeline": "node scripts/release/run-release-pipeline.mjs",
    "release:pipeline:dry-run": "node scripts/release/run-release-pipeline.mjs --dry-run",
    "release:verify-published": "node scripts/release/verify-published-release.mjs",
    "review:greptile": "greptile review --agent",
    "review:greptile:gate": "node scripts/release/greptile-review-gate.mjs",
    "security:scan": "node scripts/check-secrets.mjs",
    "smoke:npx": "node scripts/smoke-npx-from-pack.mjs",
    "sentry:telemetry:gate": "node scripts/release/sentry-telemetry-gate.mjs",
    "sentry:inject": "sentry-cli sourcemaps inject dist/",
    "sentry:upload": "sentry-cli sourcemaps upload --org unbrained --project pm-cli --release \"pm-cli@$npm_package_version\" --validate dist/",
    "build:sentry": "pnpm build && pnpm sentry:inject && pnpm sentry:upload",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "cli",
    "project-management",
    "agents",
    "ai",
    "git-native",
    "typescript",
    "task-tracker",
    "coding-agents"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "peerDependencies": {
    "typebox": "*"
  },
  "peerDependenciesMeta": {
    "typebox": {
      "optional": true
    }
  },
  "dependencies": {
    "@sentry/node": "^10.63.0",
    "@toon-format/toon": "^2.3.0",
    "commander": "^15.0.0",
    "fast-glob": "^3.3.3",
    "fast-json-patch": "^3.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sentry/cli": "^3.6.0",
    "@types/node": "^22.20.1",
    "@vitest/coverage-v8": "^4.1.9",
    "esbuild": "0.28.1",
    "eslint": "^10.6.0",
    "eslint-plugin-sonarjs": "^4.1.0",
    "eslint-plugin-unicorn": "^70.0.0",
    "greptile": "^3.1.1",
    "jscpd": "^5.0.11",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  }
}
