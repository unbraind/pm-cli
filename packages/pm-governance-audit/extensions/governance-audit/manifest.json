    "process_spawn": false
  },
  "capabilities": ["commands", "schema", "hooks"],
  "manifest_version": 1,
  "pm_min_version": "2026.5.0",
  "activation": {
    "commands": ["comments-audit", "dedupe-audit", "dedupe-merge", "normalize"]
  }
}
