{
  "name": "builtin-guide-shell",
  "version": "0.1.0",
  "entry": "./index.js",
  "priority": 0,
  "trusted": true,
  "sandbox_profile": "strict",
  "permissions": {
    "fs_read": true,
    "fs_write": false,
    "network": false,
    "env_read": true,
    "env_write": false,
    "process_spawn": false
  },
  "capabilities": ["commands", "schema", "services"],
  "manifest_version": 1,
  "pm_min_version": "2026.5.0",
  "activation": {
    "commands": ["completion", "completion-statuses", "completion-tags", "completion-types", "guide"]
  }
}
