{
  "name": "builtin-calendar",
  "version": "0.1.0",
  "entry": "./index.ts",
  "priority": 0,
  "trusted": true,
  "sandbox_profile": "strict",
  "permissions": {
    "fs_read": true,
    "fs_write": false,
    "network": false,
    "env_read": true,
    "env_write": false,
    "process_spawn": false
  },
  "capabilities": ["commands", "schema", "services"],
  "manifest_version": 1,
  "pm_min_version": "2026.6.24",
  "activation": {
    "commands": ["cal", "calendar"]
  }
}
